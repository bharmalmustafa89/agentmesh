{
  "name": "agentmesh",
  "version": "0.1.0",
  "description": "A shareable wrapper that wires agents (Goose), models (Claude/GPT/Ollama), and tools (MCP servers) into one coherent setup.",
  "type": "module",
  "bin": {
    "agentmesh": "bin/agentmesh.mjs"
  },
  "files": [
    "bin",
    "lib",
    "goose",
    "recipes",
    "docs",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test --test-reporter=spec test/"
  },
  "keywords": [
    "goose",
    "mcp",
    "agent",
    "ai",
    "cli",
    "workflow"
  ],
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
