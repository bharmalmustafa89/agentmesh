# Required: at least one provider key (or run Ollama locally for no key needed).
ANTHROPIC_API_KEY=

# Optional providers
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── MCP server credentials ──────────────────────────────────────────────────
# Only needed for the servers you uncomment in ~/.config/goose/config.yaml.

# Linear (official remote): NO env var needed — OAuth in browser at first use.
# Notion (official remote): NO env var needed — OAuth in browser at first use.

# GitHub: personal access token with repo + read:org scopes.
GITHUB_TOKEN=

# Slack (korotovsky/slack-mcp-server): use BROWSER tokens, not bot tokens.
# See https://github.com/korotovsky/slack-mcp-server#extracting-tokens for how to get them.
SLACK_XOXC_TOKEN=
SLACK_XOXD_TOKEN=

# Google Workspace (mcp-gsuite): does NOT use env vars.
# Place ~/.config/agentmesh/.gauth.json (OAuth client) and
# ~/.config/agentmesh/.accounts.json (account list) per mcp-gsuite README:
#   https://github.com/MarkusPfundstein/mcp-gsuite
